/*
  # Prevent clickjacking
  X-Frame-Options: DENY

  # Prevent MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer policy - don't leak URL to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features we don't use
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), interest-cohort=()

  # HSTS - force HTTPS for 1 year, include subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # XSS protection (legacy browsers)
  X-XSS-Protection: 1; mode=block

  # Hide tech stack
  X-Powered-By: organic-goodness

  # Content Security Policy
  # - default-src: only self
  # - style-src: self + Google Fonts
  # - font-src: self + Google Fonts CDN
  # - script-src: self + Fuse.js from CDN (SRI enforced in HTML)
  # - img-src: self + data URIs (for inline SVGs)
  # - connect-src: self only (no external API calls)
  # - frame-src: none
  # - object-src: none (blocks Flash/plugins)
  # - base-uri: self (prevents base tag injection attacks)
  # - form-action: self (prevents form hijacking)
  Content-Security-Policy: default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

  # Cache static assets aggressively (CF also caches at edge)
  Cache-Control: public, max-age=3600

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.json
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff
